# Supabase public (anon) key — safe to expose in browser builds
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_PROJECT_ID=your-project-id

# VITE_ prefix copies are required for Vite client-side injection
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ---- SERVER-SIDE ONLY (never expose to client) ----
# Supabase service role key — bypasses RLS. Keep in Cloudflare Secrets or .dev.vars only.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# HERMES ingest shared secret — must match what the MT5 Python bot sends in x-hermes-secret header.
# Keep in Cloudflare Secrets or .dev.vars only.
HERMES_INGEST_SECRET=your-hermes-ingest-secret
